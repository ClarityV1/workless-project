{
  "manifest_version": 3,
  "name": "WorkLess Apprentice",
  "version": "1.1",
  "permissions": ["storage", "activeTab"],
  "externally_connectable": {
    "matches": ["https://YOUR_GITHUB_USERNAME.github.io/*"]
  },
  "action": { "default_popup": "popup.html" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }]
}